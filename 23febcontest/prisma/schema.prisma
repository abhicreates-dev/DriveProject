// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id   String  @id @default(uuid())
  email String  @unique
  name String
  password String
  folders Folder[]
}

model Folder {
  id String  @id @default(uuid())
  title String 
  parentId String?
  userId String
  user User @relation(fields: [userId], references: [id])
  parent Folder?    @relation(name: "self", fields: [parentId], references: [id])
  childrenFolder  Folder[]  @relation("self")
  childrenFiles   File[]
}

model File{
  id String  @id @default(uuid())
  title String 
  type Type
  fileLink String?
  parentId String?
  userId String
  parent  Folder?     @relation(fields: [parentId], references: [id])
}

enum Type {
  pdf
  Video
}